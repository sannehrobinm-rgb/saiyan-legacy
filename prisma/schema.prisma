generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Character {
  id              Int              @id @default(autoincrement())
  name            String
  race            String?
  description     String?
  image           String?
  powerLevel      Int?
  role            String?
  saga            String?
  createdAt       DateTime         @default(now())

  transformations Transformation[]
  sourceRelations Relationship[]   @relation("SourceCharacter")
  targetRelations Relationship[]   @relation("TargetCharacter")
}

model Transformation {
  id          Int       @id @default(autoincrement())
  name        String
  level       Int?
  description String?
  trigger     String?
  color       String?
  image       String?

  characterId Int
  character   Character @relation(fields: [characterId], references: [id])
}

model Relationship {
  id          Int       @id @default(autoincrement())
  type        String
  description String?

  sourceId    Int
  targetId    Int

  source      Character @relation("SourceCharacter", fields: [sourceId], references: [id])
  target      Character @relation("TargetCharacter", fields: [targetId], references: [id])
}